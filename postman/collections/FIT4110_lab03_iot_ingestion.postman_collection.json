    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "POST boundary high temperature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"sensor-004\",\n  \"metric\": \"temperature\",\n  \"value\": 80,\n  \"unit\": \"celsius\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('High temperature accepted with warning or rejected', function () { pm.expect([201,400,422]).to.include(pm.response.code); if (pm.response.code === 201) { pm.expect(pm.response.json()).to.have.property('readingId'); } if ([400,422].includes(pm.response.code)) { pm.expect(pm.response.json()).to.have.property('detail'); } });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET max limit boundary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/readings?limit=100",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings?limit=100"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Max limit is accepted', function () { pm.expect([200]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET rate limit behavior documented",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/readings?limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings?limit=10"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Normal or rate-limited response is documented', function () { pm.expect([200,429]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        }
      ]
    },
