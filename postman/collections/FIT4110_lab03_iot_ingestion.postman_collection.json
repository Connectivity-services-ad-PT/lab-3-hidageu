{
  "info": {
    "name": "FIT4110_lab03_iot_ingestion",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Health response has status', function () { const json = pm.response.json(); pm.expect(json).to.have.property('status'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST create valid reading",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"sensor-001\",\n  \"metric\": \"temperature\",\n  \"value\": 28.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-25T08:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has readingId', function () { const json = pm.response.json(); pm.expect(json).to.have.property('readingId'); });",
                  "pm.test('Response metric is valid', function () { const json = pm.response.json(); pm.expect(['temperature','humidity','motion','smoke']).to.include(json.metric); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET latest readings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/readings?metric=temperature&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings?metric=temperature&limit=10"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has items array', function () { const json = pm.response.json(); pm.expect(json).to.have.property('items'); pm.expect(json.items).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET reading detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/readings/rd-1001",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings",
                "rd-1001"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has detail fields', function () { const json = pm.response.json(); pm.expect(json).to.have.property('readingId'); pm.expect(json).to.have.property('deviceId'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST valid token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"sensor-002\",\n  \"metric\": \"humidity\",\n  \"value\": 60,\n  \"unit\": \"percent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Valid token returns success or mock-compatible status', function () { pm.expect([200,201]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST missing token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"sensor-002\",\n  \"metric\": \"humidity\",\n  \"value\": 60,\n  \"unit\": \"percent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unauthorized request returns 401 or 403', function () { pm.expect([401,403]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST wrong token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "wrong-token",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"sensor-002\",\n  \"metric\": \"humidity\",\n  \"value\": 60,\n  \"unit\": \"percent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.environment.get('env') === 'mock') {",
"    pm.test('Mock auth limitation documented', function () {",
"        pm.expect([200,201,401,403]).to.include(pm.response.code);",
"    });",
"} else {",
"    pm.test('Wrong token returns 401 or 403', function () {",
"        pm.expect([401,403]).to.include(pm.response.code);",
"    });",
"}"
                ]
              }
            }
          ]
        }
      ]
    },
